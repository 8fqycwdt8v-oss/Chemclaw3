# Chemclaw environment configuration — copy to `.env` and adjust.
#
# Every value maps to a field in `chemclaw/config.py` (prefix CHEMCLAW_), and
# this file lists every field, at its default. The defaults match
# `infra/docker-compose.yml`, so the local dev stack works with no `.env` at
# all; override here to point at other environments.

# Temporal frontend gRPC endpoint and namespace (durable job execution).
CHEMCLAW_TEMPORAL_ADDRESS=localhost:7233
CHEMCLAW_TEMPORAL_NAMESPACE=default

# Task queues: heavy HPC/QM jobs vs. light background jobs (sync, re-index, reports).
CHEMCLAW_HPC_TASK_QUEUE=hpc-jobs
CHEMCLAW_BACKGROUND_TASK_QUEUE=background-jobs

# Postgres/pgvector connection (fingerprint store + calculation cache) and the
# libpq connect timeout (fail fast when the database is unreachable).
CHEMCLAW_POSTGRES_DSN=postgresql://chemclaw:chemclaw@localhost:5432/chemclaw
CHEMCLAW_PG_CONNECT_TIMEOUT_SECONDS=10

# QM job timing (seconds). The mock_* values shape the simulated HPC job only.
# The poll interval must stay below the heartbeat timeout (validated at startup).
CHEMCLAW_QM_ACTIVITY_TIMEOUT_SECONDS=30.0
CHEMCLAW_QM_POLL_HEARTBEAT_TIMEOUT_SECONDS=10.0
CHEMCLAW_HPC_POLL_INTERVAL_SECONDS=2.0
CHEMCLAW_HPC_MOCK_SUBMIT_SECONDS=1.0
CHEMCLAW_HPC_MOCK_RUN_SECONDS=6.0

# xTB semiempirical calculator: GFN parametrization + RDKit 3D-embedding seed
# (both are part of the cache key — changing them recomputes).
CHEMCLAW_XTB_METHOD=GFN2-xTB
CHEMCLAW_XTB_EMBED_SEED=42

# xTB pKa predictor: solvent + linear calibration + reported model uncertainty.
CHEMCLAW_PKA_SOLVENT=water
CHEMCLAW_PKA_CALIBRATION_SLOPE=0.28733
CHEMCLAW_PKA_CALIBRATION_INTERCEPT=-29.3116
CHEMCLAW_PKA_UNCERTAINTY=1.6

# Solubility model: reported log-S RMSE attached to every prediction.
CHEMCLAW_SOLUBILITY_RMSE_LOG=0.75

# Bayesian-optimization campaign: per-activity budget + reproducibility seed.
CHEMCLAW_BO_ACTIVITY_TIMEOUT_SECONDS=300.0
CHEMCLAW_BO_SEED=42

# MAF agent: orchestration model name and where SKILL.md files are discovered.
CHEMCLAW_AGENT_MODEL=claude-sonnet-5
CHEMCLAW_SKILLS_DIR=skills

# Markdown knowledge graph + PR-gate git settings. `note_repo_dir` is the
# checkout the note submitter mutates — point it at a dedicated clone in
# production ("." only suits a dev checkout with nothing else running in it).
CHEMCLAW_KNOWLEDGE_DIR=knowledge
CHEMCLAW_NOTE_BASE_BRANCH=main
CHEMCLAW_GIT_REMOTE=origin
CHEMCLAW_NOTE_REPO_DIR=.
CHEMCLAW_NOTE_WRITE_TIMEOUT_SECONDS=120.0
CHEMCLAW_NOTE_WRITE_MAX_ATTEMPTS=3

# Evaluation layer: versioned case-set directory, metric gates, prediction
# tolerance, and the (global) A/B noise floor.
CHEMCLAW_EVAL_CASE_DIR=evals/cases
CHEMCLAW_EVAL_EFACTOR_MAX=50.0
CHEMCLAW_EVAL_PMI_MAX=50.0
CHEMCLAW_EVAL_PREDICTION_TOLERANCE=1.0
CHEMCLAW_EVAL_AB_EPSILON=0.0

# Fingerprint search: ECFP4/DRFP definitions (must match the bit(N) columns in
# infra/sql) and the generic search knobs.
CHEMCLAW_ECFP_RADIUS=2
CHEMCLAW_ECFP_BITS=2048
CHEMCLAW_DRFP_BITS=2048
CHEMCLAW_FINGERPRINT_TOP_K=10
CHEMCLAW_FINGERPRINT_SIMILARITY_THRESHOLD=0.3

# ELN ingestion: export directory of the JSON adapter + one sync batch's budget.
CHEMCLAW_ELN_EXPORT_DIR=eln/exports
CHEMCLAW_ELN_SYNC_TIMEOUT_SECONDS=300.0
# Directory the native Open Reaction Database (ORD JSON) adapter reads.
CHEMCLAW_ORD_EXPORT_DIR=eln/exports/ord

# Memory layers: playbook similarity floor + synthesis job budget.
CHEMCLAW_PLAYBOOK_SIMILARITY_THRESHOLD=0.5
CHEMCLAW_MEMORY_JOB_TIMEOUT_SECONDS=300.0

# Report harness: per-section retrieval budget + evidence excerpt length.
CHEMCLAW_REPORT_SECTION_TIMEOUT_SECONDS=300.0
CHEMCLAW_REPORT_EXCERPT_CHARS=240

# The agent's chat client reads its provider API key from its own native env var
# (NOT a CHEMCLAW_ setting). For the default Anthropic client, set:
# ANTHROPIC_API_KEY=sk-ant-...
