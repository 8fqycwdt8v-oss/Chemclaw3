# Chemclaw environment configuration — copy to `.env` and adjust.
#
# Every value maps to a field in `chemclaw/config.py` (prefix CHEMCLAW_), and
# this file lists every field, at its default. The defaults match
# `infra/docker-compose.yml`, so the local dev stack works with no `.env` at
# all; override here to point at other environments.

# Logging: one verbosity switch for troubleshooting (raise to DEBUG) + the line format.
# Applied at each worker's entrypoint by chemclaw.logging.configure_logging.
CHEMCLAW_LOG_LEVEL=INFO
CHEMCLAW_LOG_FORMAT=%(asctime)s %(levelname)s %(name)s: %(message)s
# GxP tool-audit trail: max characters of a tool call's arguments logged per audit line.
CHEMCLAW_AGENT_AUDIT_MAX_ARG_CHARS=200
# Deployment revision (Git SHA / image digest) stamped onto every audit row (AG-14). The F6 image
# build sets this; "unknown" until then.
CHEMCLAW_DEPLOYMENT_REVISION=unknown
# OpenTelemetry export (off by default). Enable to emit spans/metrics to an OTLP collector
# configured via the standard OTEL_EXPORTER_OTLP_ENDPOINT env var; requires the OpenTelemetry
# SDK + OTLP exporter extras installed. Sensitive data (prompts/results) stays off unless set.
CHEMCLAW_OTEL_ENABLED=false
CHEMCLAW_OTEL_INCLUDE_SENSITIVE_DATA=false

# Temporal frontend gRPC endpoint and namespace (durable job execution).
CHEMCLAW_TEMPORAL_ADDRESS=localhost:7233
CHEMCLAW_TEMPORAL_NAMESPACE=default

# Task queues: heavy HPC/QM jobs vs. light background jobs (sync, re-index, reports).
CHEMCLAW_HPC_TASK_QUEUE=hpc-jobs
CHEMCLAW_BACKGROUND_TASK_QUEUE=background-jobs

# Postgres/pgvector connection (fingerprint store + calculation cache) and the
# libpq connect timeout (fail fast when the database is unreachable).
CHEMCLAW_POSTGRES_DSN=postgresql://chemclaw:chemclaw@localhost:5432/chemclaw
CHEMCLAW_PG_CONNECT_TIMEOUT_SECONDS=10

# QM job timing (seconds). The mock_* values shape the simulated HPC job only.
# The poll interval must stay below the heartbeat timeout (validated at startup).
CHEMCLAW_QM_ACTIVITY_TIMEOUT_SECONDS=30.0
CHEMCLAW_QM_POLL_HEARTBEAT_TIMEOUT_SECONDS=10.0
CHEMCLAW_HPC_POLL_INTERVAL_SECONDS=2.0
CHEMCLAW_HPC_MOCK_SUBMIT_SECONDS=1.0
CHEMCLAW_HPC_MOCK_RUN_SECONDS=6.0

# xTB semiempirical calculator: GFN parametrization + RDKit 3D-embedding seed
# (both are part of the cache key — changing them recomputes).
CHEMCLAW_XTB_METHOD=GFN2-xTB
CHEMCLAW_XTB_EMBED_SEED=42

# xTB pKa predictor: solvent + linear calibration + reported model uncertainty.
CHEMCLAW_PKA_SOLVENT=water
CHEMCLAW_PKA_CALIBRATION_SLOPE=0.28733
CHEMCLAW_PKA_CALIBRATION_INTERCEPT=-29.3116
CHEMCLAW_PKA_UNCERTAINTY=1.6

# Solubility model: reported log-S RMSE attached to every prediction.
CHEMCLAW_SOLUBILITY_RMSE_LOG=0.75

# Bayesian-optimization campaign: per-activity budget + reproducibility seed.
CHEMCLAW_BO_ACTIVITY_TIMEOUT_SECONDS=300.0
CHEMCLAW_BO_SEED=42

# MAF agent: orchestration model name and where SKILL.md files are discovered.
# SKILLS_DIR is one or more directories, OS-path-separator delimited like PATH
# (e.g. skills:/opt/team-skills), so a second skills directory needs no code change.
CHEMCLAW_AGENT_MODEL=claude-sonnet-5
CHEMCLAW_SKILLS_DIR=skills
# Role-scoped skill visibility (Phase 6): JSON map of skill name -> allowed Entra app-roles.
# A listed skill is hidden from a caller holding none of its roles; unlisted skills stay visible
# to all. Empty default = every skill visible. e.g. {"deep-research": ["process-chemist"]}
CHEMCLAW_SKILL_ROLE_GATES={}
# Testing CLI (`make chat` / `uv run chemclaw --admin`): the audit actor that admin-mode
# (auth-bypass, for use when CHEMCLAW_ENTRA_REQUIRED=false) runs are attributed to.
CHEMCLAW_CLI_ADMIN_ACTOR=admin@localhost
# MCP capability servers the agent attaches over stdio (fingerprint search). Defaults
# (mcp-molfp, mcp-rxnfp) live in chemclaw/config.py; override as a JSON list of
# {name, command, args, allowed_tools} to add/replace servers, e.g.:
# CHEMCLAW_MCP_SERVERS='[{"name":"mcp-molfp","command":"python","args":["-m","mcp_servers.molfp.server"],"allowed_tools":["similar_molecules","substructure_matches"]}]'
# Conversation context management. Compaction fires only when the running chat exceeds the
# token budget (char/4 estimate), then collapses stale tool-result dumps (keeping the newest
# N tool groups verbatim) and slides the conversation window; system instructions are kept.
CHEMCLAW_AGENT_CONTEXT_TOKEN_BUDGET=100000
CHEMCLAW_AGENT_KEEP_LAST_TOOL_GROUPS=2
CHEMCLAW_AGENT_KEEP_LAST_CONVERSATION_GROUPS=12

# Markdown knowledge graph + PR-gate git settings. `note_repo_dir` is the
# checkout the note submitter mutates — point it at a dedicated clone in
# production ("." only suits a dev checkout with nothing else running in it).
CHEMCLAW_KNOWLEDGE_DIR=knowledge
# Cache the parsed graph so retrieval does not re-parse the whole tree per query (KM-14); any note
# change busts it. Off makes every query re-parse.
CHEMCLAW_GRAPH_CACHE_ENABLED=true
# Max link-expansion depth for the expand_note tool (SEC-4; larger values are clamped).
CHEMCLAW_GRAPH_MAX_HOPS=3
CHEMCLAW_NOTE_BASE_BRANCH=main
CHEMCLAW_GIT_REMOTE=origin
CHEMCLAW_NOTE_REPO_DIR=.
CHEMCLAW_NOTE_WRITE_TIMEOUT_SECONDS=120.0
CHEMCLAW_NOTE_WRITE_MAX_ATTEMPTS=3
# Wall-clock bound (seconds) on a single git command in the PR-gate submitter; a hung
# fetch/push is killed so it can never deadlock the process-wide submit lock.
CHEMCLAW_GIT_COMMAND_TIMEOUT_SECONDS=60.0
# Max attempts for activities under the shared bad-data retry policy: caps transient
# retries so an unclassified deterministic failure gives up instead of retrying forever.
CHEMCLAW_ACTIVITY_MAX_ATTEMPTS=5
# How long (seconds) a confirmed-answer note is held pending a human Yes/No (the chat
# "save knowledge?" button) before the hold expires unpublished. Default 7 days.
CHEMCLAW_INTERACTION_APPROVAL_TIMEOUT_SECONDS=604800.0

# Evaluation layer: versioned case-set directory, metric gates, prediction
# tolerance, and the (global) A/B noise floor.
CHEMCLAW_EVAL_CASE_DIR=evals/cases
CHEMCLAW_EVAL_EFACTOR_MAX=50.0
CHEMCLAW_EVAL_PMI_MAX=50.0
CHEMCLAW_EVAL_PREDICTION_TOLERANCE=1.0
CHEMCLAW_EVAL_AB_EPSILON=0.0
# F10-F2 — eval drift detection. Off by default; enabling adds a background Schedule that re-runs the
# committed case-set and alerts when an aggregate metric moves past a *relative* band (epsilon ×
# baseline value, so one knob fits metrics of different scales) vs the committed baseline.
CHEMCLAW_EVAL_DRIFT_ENABLED=false
CHEMCLAW_EVAL_DRIFT_SCHEDULE_MINUTES=1440
CHEMCLAW_EVAL_DRIFT_EPSILON=0.05
CHEMCLAW_EVAL_DRIFT_TIMEOUT_SECONDS=300.0
CHEMCLAW_EVAL_BASELINE_PATH=evals/baseline.json
# Retrieval-quality gate (KM-13): the gold-set corpus fixture + the recall floor the
# retrieval_recall metric gates against.
CHEMCLAW_EVAL_RETRIEVAL_CORPUS_DIR=evals/retrieval_corpus
CHEMCLAW_RETRIEVAL_RECALL_MIN=0.75

# Fingerprint search: ECFP4/DRFP definitions (must match the bit(N) columns in
# infra/sql) and the generic search knobs.
CHEMCLAW_ECFP_RADIUS=2
CHEMCLAW_ECFP_BITS=2048
CHEMCLAW_DRFP_BITS=2048
CHEMCLAW_FINGERPRINT_TOP_K=10
CHEMCLAW_FINGERPRINT_SIMILARITY_THRESHOLD=0.3

# ELN ingestion: export directory of the JSON adapter + one sync batch's budget.
CHEMCLAW_ELN_EXPORT_DIR=eln/exports
CHEMCLAW_ELN_SYNC_TIMEOUT_SECONDS=300.0
# Directory the native Open Reaction Database (ORD JSON) adapter reads.
CHEMCLAW_ORD_EXPORT_DIR=eln/exports/ord
# Which sources the sync ingests is set by CHEMCLAW_DATA_SOURCES (below); each active ingest
# source carries its own high-water cursor in `sync_cursors`, keyed by its registry name.

# Memory layers: playbook similarity floor + synthesis job budget.
CHEMCLAW_PLAYBOOK_SIMILARITY_THRESHOLD=0.5
# Optimization campaigns group repeated runs of the SAME transformation (tighter floor).
CHEMCLAW_OPTIMIZATION_SIMILARITY_THRESHOLD=0.7
CHEMCLAW_MEMORY_JOB_TIMEOUT_SECONDS=300.0

# Report harness: per-section retrieval budget + evidence excerpt length.
CHEMCLAW_REPORT_SECTION_TIMEOUT_SECONDS=300.0
CHEMCLAW_REPORT_EXCERPT_CHARS=240
# Max evidence chunks one gather_evidence sweep hands the agent (context-window budget).
CHEMCLAW_GATHER_EVIDENCE_MAX_CHUNKS=40
# F10-D — child-workflow fan-out: cap on concurrent children (report sections, memory groups).
CHEMCLAW_ORCHESTRATOR_MAX_PARALLEL_CHILDREN=8

# F10-A — hybrid retrieval. `hash` embedder is offline dev; `openai_compatible` uses the internal
# /embeddings endpoint. embedding_dim must match note_index.embedding vector(N) (infra/sql/010).
# retrieval_mode `graph` keeps the flat union (default); `hybrid` fuses sources by RRF. The vector/
# lexical retrievers are enabled by adding `vector`/`lexical` to CHEMCLAW_DATA_SOURCES.
CHEMCLAW_EMBEDDING_PROVIDER=hash
CHEMCLAW_EMBEDDING_MODEL=
CHEMCLAW_EMBEDDING_DIM=1536
CHEMCLAW_RETRIEVAL_TOP_K=8
CHEMCLAW_RETRIEVAL_MODE=graph
CHEMCLAW_RETRIEVAL_FUSION_K=60
# Neutral score for a graph hit whose note has no confidence, used to rank-before-truncate (KM-5).
CHEMCLAW_RETRIEVAL_DEFAULT_CONFIDENCE=0.5

# The agent's chat client reads its provider API key from its own native env var
# (NOT a CHEMCLAW_ setting). For the default Anthropic client, set:
# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# Foundation build F0–F7 (real target stack). Every value below is a Settings
# field; defaults keep local dev working with no tenant/cluster.
# ─────────────────────────────────────────────────────────────────────────────

# F0 — LLM provider seam. `openai_compatible` points at the internal endpoint with ONE generic
# API credential (not Entra — the documented exception); `anthropic` is the dev fallback.
CHEMCLAW_LLM_PROVIDER=anthropic
CHEMCLAW_LLM_BASE_URL=
CHEMCLAW_LLM_MODEL=
CHEMCLAW_LLM_API_KEY=
CHEMCLAW_LLM_TLS_CA_BUNDLE=
CHEMCLAW_LLM_TIMEOUT_SECONDS=60.0
CHEMCLAW_LLM_MAX_RETRIES=3
CHEMCLAW_LLM_TEMPERATURE=0.0
CHEMCLAW_LLM_MAX_TOKENS=4096
# F10-E — per-task model routing (JSON task->model; empty keeps the single default model).
CHEMCLAW_MODEL_ROUTES={}
# F10-B — answer verification. When enabled, a drafted answer is scored for citation faithfulness by
# an LLM judge on the routed `verifier` model; an answer below the threshold is flagged for human
# review. Disabled = the deterministic report citation check, offline, no behavior change.
CHEMCLAW_VERIFIER_ENABLED=false
CHEMCLAW_VERIFIER_CONFIDENCE_THRESHOLD=0.7

# F1 — autonomous plan/execute harness (off keeps today's classic agent).
CHEMCLAW_HARNESS_ENABLED=false
CHEMCLAW_HARNESS_AUTONOMY=plan_only
CHEMCLAW_HARNESS_MAX_LOOP_ITERATIONS=25

# F2 — front-door service (FastAPI + SSE).
CHEMCLAW_SERVICE_HOST=0.0.0.0
CHEMCLAW_SERVICE_PORT=8080
CHEMCLAW_SERVICE_CORS_ORIGINS=
# Max characters accepted in one chat message (SEC-4; oversized -> 422).
CHEMCLAW_SERVICE_MAX_MESSAGE_CHARS=100000
# Response security headers (CSP/nosniff/frame-deny/HSTS) on the browser surface. On by default;
# set false only when an ingress/Route fronts its own header policy.
CHEMCLAW_SERVICE_SECURITY_HEADERS=true

# F3 — durable sessions + job→session push-back (postgres store opt-in).
CHEMCLAW_SESSION_STORE=memory
CHEMCLAW_SESSION_STORE_DSN=
CHEMCLAW_SESSION_EVENT_POLL_SECONDS=2.0
# Cap on the front door's in-process live-session cache (LRU-evicted past this; COR-3).
CHEMCLAW_SERVICE_MAX_LIVE_SESSIONS=1000
# Admission control (AG-15): max concurrent agent turns, and how long a turn waits for a permit
# before it is shed with 503. Tune the cap to the internal LLM endpoint's throughput.
CHEMCLAW_SERVICE_MAX_CONCURRENT_TURNS=8
CHEMCLAW_SERVICE_TURN_ADMISSION_TIMEOUT_SECONDS=5.0

# F4 — Entra identity & RBAC (system-wide; enforced only when ENTRA_REQUIRED=true).
CHEMCLAW_ENTRA_REQUIRED=false
CHEMCLAW_ENTRA_TENANT_ID=
CHEMCLAW_ENTRA_CLIENT_ID=
CHEMCLAW_ENTRA_AUDIENCE=
CHEMCLAW_ENTRA_JWKS_URL=
CHEMCLAW_ENTRA_ISSUER=
CHEMCLAW_ENTRA_EXPENSIVE_ACTIONS=
CHEMCLAW_ENTRA_PRIVILEGED_ROLES=
# F10-C — per-tool authorization (enforced only under ENTRA_REQUIRED). JSON tool->roles; the
# default policy for an ungated tool is `allow` (today's behavior) or `deny` (allowlist mode).
CHEMCLAW_TOOL_ROLE_GATES={}
CHEMCLAW_TOOL_AUTHZ_DEFAULT=allow
CHEMCLAW_SERVICE_ACTOR_ID=service-account
# Workload identity federation (F4-T2) + OBO (F4-T4): no client secret at rest.
CHEMCLAW_ENTRA_WORKLOAD_FEDERATION_ENABLED=false
CHEMCLAW_ENTRA_WORKLOAD_CLIENT_ID=
CHEMCLAW_ENTRA_TOKEN_ENDPOINT=
CHEMCLAW_ENTRA_SA_TOKEN_PATH=/var/run/secrets/azure/tokens/azure-identity-token
CHEMCLAW_ENTRA_TOKEN_REFRESH_LEEWAY_SECONDS=300.0
CHEMCLAW_ENTRA_HTTP_TIMEOUT_SECONDS=10.0
CHEMCLAW_ENTRA_OBO_ENABLED=false
# Non-Entra transport bridges (F4-T6): Temporal mTLS/API-key + the HPC identity bridge.
CHEMCLAW_TEMPORAL_TLS_CERT=
CHEMCLAW_TEMPORAL_TLS_KEY=
CHEMCLAW_TEMPORAL_TLS_CA=
CHEMCLAW_TEMPORAL_API_KEY=
CHEMCLAW_HPC_BRIDGE_IDENTITY=chemclaw-hpc

# F5 — real HPC via Nextflow (mock kept for CI). Pipeline version enters the cache key when set.
CHEMCLAW_HPC_LAUNCH_INTERFACE=mock
CHEMCLAW_HPC_API_BASE_URL=
CHEMCLAW_HPC_API_TOKEN=
CHEMCLAW_HPC_PIPELINE_NAME=
CHEMCLAW_HPC_PIPELINE_VERSION=
CHEMCLAW_HPC_ARTIFACT_STORE_URL=
# Real-run poll budgets (the nextflow path; the mock uses hpc_mock_run_seconds). start_to_close must
# cover the whole run (heartbeating does not extend it); heartbeat timeout sits above one poll's
# HTTP round-trip + poll interval; the HTTP timeout bounds each launcher/artifact call.
CHEMCLAW_HPC_RUN_TIMEOUT_SECONDS=86400.0
CHEMCLAW_HPC_RUN_HEARTBEAT_TIMEOUT_SECONDS=120.0
CHEMCLAW_HPC_HTTP_TIMEOUT_SECONDS=30.0

# F6 — OTLP collector endpoint (bridged to OTEL_EXPORTER_OTLP_ENDPOINT).
CHEMCLAW_OTEL_ENDPOINT=

# F7 — active data sources on the generic seam (registry keys, comma list).
CHEMCLAW_DATA_SOURCES=graph,eln-json

# Pre-existing fields previously omitted from this file.
CHEMCLAW_PG_STATEMENT_TIMEOUT_SECONDS=30.0
CHEMCLAW_ELN_SYNC_SCHEDULE_MINUTES=60.0
CHEMCLAW_MEMORY_SYNTHESIS_SCHEDULE_MINUTES=1440.0
CHEMCLAW_NOTE_EXCERPT_CHARS=240
